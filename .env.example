# Report Convertor — S3 Configuration
# Copy this file to .env and fill in your values.
# Place .env in the same directory as report-convertor.exe

S3_BUCKET=your-bucket-name
S3_FOLDER=path/to/templates/
S3_REPORT_FOLDER=path/to/reports/
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
